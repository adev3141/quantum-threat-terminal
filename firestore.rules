rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Legacy public terminal documents (kept readable for compatibility during migration).
    match /global/metrics {
      allow read: if true;
      allow write: if false;
    }

    match /global/metrics_methodology {
      allow read: if true;
      allow write: if false;
    }

    match /global/metriq_frontier {
      allow read: if true;
      allow write: if false;
    }

    match /global/risk_methodology {
      allow read: if true;
      allow write: if false;
    }

    match /global/risk_signals {
      allow read: if true;
      allow write: if false;
    }

    // Benchmark-native public terminal documents.
    match /global/benchmark_frontier {
      allow read: if true;
      allow write: if false;
    }

    match /global/readiness_projection {
      allow read: if true;
      allow write: if false;
    }

    match /global/threat_signals {
      allow read: if true;
      allow write: if false;
    }

    match /global/benchmark_methodology {
      allow read: if true;
      allow write: if false;
    }

    match /companies/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /market_snapshots/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /news_feed/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /risk_reference/{document} {
      allow read, write: if false;
    }

    match /crypto_reference/{document} {
      allow read, write: if false;
    }

    match /crypto_reference_history/{document} {
      allow read, write: if false;
    }

    match /global_metrics_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /global_metrics_methodology_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /global_metriq_frontier_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /global_risk_methodology_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /global_risk_signals_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Benchmark-native history collections.
    match /global_benchmark_frontier_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /global_readiness_projection_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /global_threat_signals_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /global_benchmark_methodology_history/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /ingestion_runs/{document} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
